name: Build wheel

on:
  - push

jobs:
  build-wheel:
    runs-on: ubuntu-22.04
    steps:
      - uses: actions/checkout@v6

      - name: Set up Python
        uses: actions/setup-python@v6
        with:
          python-version: "3.12"

      - name: Set up uv
        uses: astral-sh/setup-uv@v6

      - name: Build wheel
        run: uv build --wheel

      - name: Upload wheel artifact
        uses: actions/upload-artifact@v4
        with:
          name: wheel
          path: dist/*.whl

  test-wheel:
    runs-on: ubuntu-22.04
    needs: build-wheel
    steps:
      - name: Set up Python
        uses: actions/setup-python@v6
        with:
          python-version: "3.12"

      - name: Set up uv
        uses: astral-sh/setup-uv@v6

      - name: Download wheel artifact
        uses: actions/download-artifact@v5
        with:
          name: wheel
          path: dist

      - name: Install wheel as tool
        run: uv tool install --from dist/*.whl "{{ project_name }}"

      - name: Check CLI help
        run: '{{ project_name }} --help'
